# LLM runtime
BASE_URL=http://127.0.0.1:11434/v1
API_KEY=ollama
MODEL=llama3
TEMPERATURE=0.7
MAX_TOKENS=500

# MCP transport
# Leave MCP_BASE_URL empty to use the in-process local loopback transport.
MCP_TRANSPORT=local
MCP_PROTOCOL_VERSION=2025-11-25
MCP_BASE_URL=
MCP_API_KEY=
MCP_TIMEOUT_SECONDS=10
